<%- include('../partials/header', { title: 'My Courses - SLMS' }) %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h2>My Courses</h2>
            <div class="action-buttons">
                <a href="/teacher/courses/create" class="btn btn-primary">Create New Course</a>
            </div>
        </div>

        <% if (courses.length === 0) { %>
            <p>You haven't created any courses yet. <a href="/teacher/courses/create">Create your first course</a></p>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Course Title</th>
                        <th>Level</th>
                        <th>Description</th>
                        <th>Students</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% courses.forEach(course => { %>
                        <tr>
                            <td><strong><%= course.title %></strong></td>
                            <td><span class="badge badge-info"><%= primaryLevelLabel(course.primary_level) %></span></td>
                            <td><%= course.description || 'No description' %></td>
                            <td><%= course.student_count || 0 %></td>
                            <td>
                                <a href="/teacher/courses/<%= course.id %>" class="btn btn-sm btn-primary">View</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
