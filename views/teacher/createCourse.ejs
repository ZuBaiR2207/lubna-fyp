<%- include('../partials/header', { title: 'Create Course - SLMS' }) %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h2>Create New Course</h2>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>

        <form action="/teacher/courses/create" method="POST">
            <div class="form-group">
                <label for="title">Course Title</label>
                <input type="text" id="title" name="title" required>
            </div>
            <div class="form-group">
                <label for="primary_level">Class level</label>
                <select id="primary_level" name="primary_level" required>
                    <option value="">Which year is this course for?</option>
                    <% primaryLevelOptions.forEach(opt => { %>
                        <option value="<%= opt.value %>"><%= opt.label %></option>
                    <% }); %>
                </select>
                <small style="color: #64748b;">Malaysian primary school: Class 1 through Class 5.</small>
            </div>
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="4"></textarea>
            </div>
            <div class="action-buttons">
                <button type="submit" class="btn btn-primary">Create Course</button>
                <a href="/teacher/courses" class="btn">Cancel</a>
            </div>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>
