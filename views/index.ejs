<%- include('partials/header', { title: 'Home - SLMS' }) %>

<div class="container">
    <div class="hero">
        <h2>Welcome to SLMS</h2>
        <p class="subtitle">Learning Management System for Private Primary Institution, Malaysia</p>
        <p>Empowering education through technology. A centralized platform for teachers, students, and parents.</p>
        <div class="cta-buttons">
            <a href="/login" class="btn btn-primary">Login</a>
        </div>
    </div>

    <div class="features-grid">
        <div class="feature-card">
            <h3>📚 Course Management</h3>
            <p>Teachers can upload and organize course materials including PDFs, documents, and images in one centralized platform.</p>
        </div>
        <div class="feature-card">
            <h3>📝 Automated Assessments</h3>
            <p>Create multiple-choice quizzes with automatic grading. Save time and provide instant feedback to students.</p>
        </div>
        <div class="feature-card">
            <h3>📊 Progress Tracking</h3>
            <p>Monitor student performance with detailed reports and analytics. Identify areas that need improvement.</p>
        </div>
        <div class="feature-card">
            <h3>👨‍👩‍👧 Parent Portal</h3>
            <p>Parents can securely view their child's academic progress, quiz results, and attendance records.</p>
        </div>
        <div class="feature-card">
            <h3>🔒 Secure Access</h3>
            <p>Role-based authentication ensures that each user only accesses information relevant to their role.</p>
        </div>
        <div class="feature-card">
            <h3>💻 Easy to Use</h3>
            <p>Intuitive interface designed for users of all technical levels. Simple navigation and clear layouts.</p>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
