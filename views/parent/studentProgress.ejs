<%- include('../partials/header', { title: student.full_name + ' - Progress' }) %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h2><%= student.full_name %> - Academic Progress</h2>
            <p><span class="badge badge-info"><%= primaryLevelLabel(student.primary_level) %></span></p>
            <p><strong>Email:</strong> <%= student.email %></p>
        </div>
    </div>

    <!-- Attendance Summary -->
    <div class="card">
        <div class="card-header">
            <h2>Attendance Summary</h2>
        </div>
        <div class="stats-grid">
            <div class="stat-card">
                <h3><%= attendance.total_records || 0 %></h3>
                <p>Total Records</p>
            </div>
            <div class="stat-card">
                <h3><%= attendance.present_count || 0 %></h3>
                <p>Present</p>
            </div>
            <div class="stat-card">
                <h3><%= attendance.absent_count || 0 %></h3>
                <p>Absent</p>
            </div>
            <div class="stat-card">
                <h3><%= attendance.late_count || 0 %></h3>
                <p>Late</p>
            </div>
        </div>
    </div>

    <!-- Enrolled Courses -->
    <div class="card">
        <div class="card-header">
            <h2>Enrolled Courses</h2>
        </div>
        <% if (courses.length === 0) { %>
            <p>Not enrolled in any courses.</p>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Course Title</th>
                        <th>Level</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    <% courses.forEach(course => { %>
                        <tr>
                            <td><strong><%= course.title %></strong></td>
                            <td><span class="badge badge-info"><%= primaryLevelLabel(course.primary_level) %></span></td>
                            <td><%= course.description || 'No description' %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </div>

    <!-- Quiz Results -->
    <div class="card">
        <div class="card-header">
            <h2>Quiz Results</h2>
        </div>
        <% if (attempts.length === 0) { %>
            <p>No quiz attempts yet.</p>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Quiz</th>
                        <th>Course</th>
                        <th>Score</th>
                        <th>Percentage</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% attempts.forEach(attempt => { %>
                        <tr>
                            <td><strong><%= attempt.quiz_title %></strong></td>
                            <td><%= attempt.course_title %></td>
                            <td><%= attempt.score %> / <%= attempt.total_marks %></td>
                            <td>
                                <span class="badge <%= attempt.percentage >= 70 ? 'badge-success' : attempt.percentage >= 50 ? 'badge-info' : 'badge-danger' %>">
                                    <%= attempt.percentage %>%
                                </span>
                            </td>
                            <td><%= new Date(attempt.attempted_at).toLocaleDateString() %></td>
                            <td>
                                <a href="/parent/quizzes/<%= attempt.id %>" class="btn btn-sm btn-primary">View Details</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </div>

    <div class="action-buttons">
        <a href="/parent/dashboard" class="btn btn-primary">Back to Dashboard</a>
    </div>
</div>

<%- include('../partials/footer') %>
