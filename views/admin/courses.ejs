<%- include('../partials/header', { title: 'All Courses - SLMS' }) %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h2>All Courses</h2>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Teacher</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% courses.forEach(course => { %>
                    <tr>
                        <td><strong><%= course.title %></strong></td>
                        <td><%= course.description || 'No description' %></td>
                        <td><%= course.teacher_name %></td>
                        <td><%= new Date(course.created_at).toLocaleDateString() %></td>
                        <td>
                            <form action="/admin/courses/<%= course.id %>/delete" method="POST" style="display: inline;">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this course? All materials, quizzes, and enrollments will be removed.')">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
